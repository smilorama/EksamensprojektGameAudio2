# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
.utmp/
/EksamensprojektUnity/[Ll]ibrary/
/EksamensprojektUnity/[Tt]emp/
/EksamensprojektUnity/[Oo]bj/
/EksamensprojektUnity/[Bb]uild/
/EksamensprojektUnity/[Bb]uilds/
/EksamensprojektUnity/[Ll]ogs/
/EksamensprojektUnity/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/EksamensprojektUnity/[Mm]emoryCaptures/

# Recordings can get excessive in size
/EksamensprojektUnity/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /EksamensprojektUnity/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/EksamensprojektUnity/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
/EksamensprojektUnity/.vs/

# Gradle cache directory
/EksamensprojektUnity/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/EksamensprojektUnity/ExportedObj/
/EksamensprojektUnity/.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
/EksamensprojektUnity/sysinfo.txt

# Mono auto generated files
/EksamensprojektUnity/mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
/EksamensprojektUnity/crashlytics-build.properties

# TestRunner generated files
/EksamensprojektUnity/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/EksamensprojektUnity/ServerData
/EksamensprojektUnity/[Aa]ssets/StreamingAssets/aa*
/EksamensprojektUnity/[Aa]ssets/AddressableAssetsData/link.xml*
/EksamensprojektUnity/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /EksamensprojektUnity/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/EksamensprojektUnity/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/EksamensprojektUnity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/EksamensprojektUnity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/EksamensprojektUnity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/EksamensprojektUnity/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/EksamensprojektUnity/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Auto-generated cache in Assets folder
/[Aa]ssets/[Ss]ceneDependencyCache*

## ---------------- ##
##   WWise stuff    ##
## ---------------- ##

# project stuff
/EksamensprojektWwise/.cache/
/EksamensprojektWwise/*.prof
/EksamensprojektWwise/*_WwiseProject.*.validationcache
/EksamensprojektWwise/*_WwiseProject.*.wsettings
/EksamensprojektWwise/**/*.akd

# build stuff (unsure?)
# /EksamensprojektUnity/Assets/Wwise/Deployment/Plugins/Windows/**/*.meta

# WWise Picker (editor)
# from https://www.audiokinetic.com/library/edge/?source=Unity&id=unity__troubleshooting.html
# >> Do not keep AkWwiseProjectData.asset under version control! 
# >> This is a temporary cache file for the Wwise project data, 
# >> so as to avoid having the Wwise Picker continuously parse the Work Unit files.
/EksamensprojektUnity/Assets/Wwise/Editor/ProjectData/AkWwiseProjectData.asset*

# notes:
# 1) if any other files go in Assets/Wwise/Editor/ProjectData/ besides AkWwiseProjectData.asset*,
#    then don't ignore Assets/Wwise/Editor/ProjectData.meta. If AkWwiseProjectData.asset is the only item in there,
#    then, it's OK to ignore this file.
# 
# Assets/Wwise/Editor/ProjectData.meta

## --------------- ##
## End WWise Stuff ##
## --------------- ##

# temp install files
/EksamensprojektUnity/WwiseUnityIntegration_*_Src.zip

# Mac stuff
.DS_store

# Jetbrains Rider IDE (C# IDE), adds a plugin to Unity
# Assets/Plugins/Editor.meta
# Assets/Plugins/Editor/Jetbrains.meta
# Assets/Plugins/Editor/Jetbrains/
# .idea


EksamensprojektWwise/EksamensprojektWwise.crossover.validationcache
*.wsettings
*.validationcache
